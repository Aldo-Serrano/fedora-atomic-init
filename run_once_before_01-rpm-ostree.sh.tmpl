#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# Phase 1: rpm-ostree package layering on Fedora Atomic host
# This runs ONCE before dotfiles are applied
# =============================================================================

{{ if ne .chezmoi.os "linux" }}
echo "Skipping rpm-ostree setup (not on Linux)"
exit 0
{{ end }}

source /etc/os-release 2>/dev/null || true

if ! command -v rpm-ostree &>/dev/null; then
    echo "[SKIP] Not on Fedora Atomic, skipping rpm-ostree layering"
    exit 0
fi

echo "[INFO] Layering packages via rpm-ostree..."

PACKAGES=(
    zsh
    util-linux-user
    fzf
    zoxide
    git
    curl
    wget
    unzip
    distrobox
    podman
    firefox
    fontconfig
)

ALREADY_INSTALLED=()
TO_INSTALL=()

for pkg in "${PACKAGES[@]}"; do
    if rpm -q "$pkg" &>/dev/null; then
        ALREADY_INSTALLED+=("$pkg")
    else
        TO_INSTALL+=("$pkg")
    fi
done

if [[ ${#ALREADY_INSTALLED[@]} -gt 0 ]]; then
    echo "[OK] Already installed: ${ALREADY_INSTALLED[*]}"
fi

if [[ ${#TO_INSTALL[@]} -gt 0 ]]; then
    echo "[INFO] Installing: ${TO_INSTALL[*]}"
    sudo rpm-ostree install --idempotent --allow-inactive "${TO_INSTALL[@]}"
    echo "[WARN] A reboot may be required. Run: systemctl reboot"
else
    echo "[OK] All packages already installed"
fi

# Set ZSH as default shell if not already
CURRENT_SHELL="$(getent passwd "$USER" | cut -d: -f7)"
if [[ "$CURRENT_SHELL" != */zsh ]]; then
    echo "[INFO] Setting ZSH as default shell..."
    sudo chsh -s "$(which zsh)" "$USER" 2>/dev/null || \
        sudo usermod -s /usr/bin/zsh "$USER" 2>/dev/null || \
        echo "[WARN] Could not change shell automatically. Run: chsh -s /usr/bin/zsh"
else
    echo "[OK] ZSH is already the default shell"
fi

echo "[OK] rpm-ostree layering complete"
